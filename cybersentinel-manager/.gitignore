# CyberSentinel .gitignore

# Environment files (NEVER commit secrets!)
.env
*.env
!.env.example

# Backup files
*.backup
backups/
*.tar.gz
*.zip

# Docker volumes data (managed by Docker)
volumes/

# Logs
*.log
logs/

# md files
*.md
!normalizer/README.md

# Temporary files
*.tmp
*.temp
*.swp
*.swo
*~

# IDE files
.idea/
.vscode/
*.sublime-*

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
ENV/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# SSL certificates (if any)
*.pem
*.key
*.crt
*.csr

# Secrets
secrets/
*.secret

# Downloaded config files (fetched by fetch-configs.sh, not committed)
config/*.conf
config/rules/*.xml
config/decoders/*.xml
config/integrations/*
config/ruleset/rules/*.xml
config/ruleset/decoders/*.xml
!config/.gitkeep
!config/rules/.gitkeep
!config/decoders/.gitkeep
!config/integrations/.gitkeep
!config/ruleset/rules/.gitkeep
!config/ruleset/decoders/.gitkeep

# Local testing
test/
tmp/
